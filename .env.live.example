# Live testnet environment (multichain)
# Copy to .env.live and fill all required values before running `just live up`.
# Tip: you can start from .env.docker.example and then add mode-specific flags below.

MODE=live-testnet
DASHBOARD_PORT=3000
CRE_BRIDGE_PORT=8080

# Live mode contracts (must remain false)
NEXT_PUBLIC_USE_MOCK=false
DEFI_MOCK_MODE=false

# Phase 1 safety switch: current CRE bridge path is still simulation-backed.
# Keep false to fail fast by default; set true only to acknowledge and proceed.
LIVE_ALLOW_SIMULATED_CRE=false

# Shared Hedera topics
HCS_TASK_TOPIC_ID=
HCS_TASK_TOPIC=
DEFI_HCS_TASK_TOPIC=
HCS_STATUS_TOPIC_ID=
HCS_RESULT_TOPIC=
DEFI_HCS_RESULT_TOPIC=
HTS_PAYMENT_TOKEN_ID=

# Coordinator
HEDERA_COORDINATOR_ACCOUNT_ID=
HEDERA_COORDINATOR_PRIVATE_KEY=
HEDERA_AGENT1_ACCOUNT_ID=
HEDERA_AGENT2_ACCOUNT_ID=
CRE_ENDPOINT=http://cre-bridge:8080/evaluate-risk

# Inference / 0G
INFERENCE_HEDERA_ACCOUNT_ID=
INFERENCE_HEDERA_PRIVATE_KEY=
INFERENCE_AGENT_ID=inference-001
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZG_CHAIN_PRIVATE_KEY=
ZG_SERVING_CONTRACT=
ZG_COMPUTE_ENDPOINT=
ZG_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
ZG_STORAGE_NODE_ENDPOINT=
ZG_STORAGE_ENDPOINT=
ZG_INFT_CONTRACT=
ZG_ENCRYPTION_KEY=
ZG_ENCRYPTION_KEY_ID=default
ZG_DA_CONTRACT=0xE75A073dA5bb7b0eC622170Fd268f35E675a957B
ZG_DA_NAMESPACE=inference-audit
ZG_DA_ENDPOINT=

# DeFi / Base Sepolia
DEFI_HEDERA_ACCOUNT_ID=
DEFI_HEDERA_PRIVATE_KEY=
DEFI_AGENT_ID=defi-001
DEFI_BASE_RPC_URL=https://sepolia.base.org
DEFI_PRIVATE_KEY=
DEFI_WALLET_ADDRESS=
DEFI_ERC8004_CONTRACT=
DEFI_DEX_ROUTER=
DEFI_BUILDER_CODE=
DEFI_ATTRIBUTION_ENABLED=true
DEFI_TOKEN_IN=0x036CbD53842c5426634e7929541eC2318f3dCF7e
DEFI_TOKEN_OUT=0x4200000000000000000000000000000000000006

# Minimum wei required in DEFI_WALLET_ADDRESS for live preflight funding gate.
LIVE_MIN_BASE_WEI=100000000000000

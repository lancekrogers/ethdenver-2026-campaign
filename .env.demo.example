# Demo mode environment (deterministic, no funded wallets required)
# Copy to .env.demo to customize local demo runs.

MODE=demo
DASHBOARD_PORT=3000
CRE_BRIDGE_PORT=8080

# Dashboard in mock mode for low-friction demos.
NEXT_PUBLIC_USE_MOCK=true

# DeFi stays in mock mode for demo safety.
DEFI_MOCK_MODE=true

# Optional: override bridge endpoint if running non-default ports.
CRE_ENDPOINT=http://cre-bridge:8080/evaluate-risk

# Fest runtime controls for demo mode (synthetic fallback enabled by default).
FEST_SELECTOR=
FEST_FALLBACK_ALLOW_SYNTHETIC=true
FEST_ALLOW_COMPLETED=true
FEST_COMMAND_TIMEOUT_SECONDS=8
FEST_POLL_INTERVAL_SECONDS=10
